# Tibet Compass — Environment Variables Example
# Copy to .env and fill in values after deployment

# AWS region
AWS_REGION=us-east-1

# DynamoDB table names (set automatically by deploy.sh via Lambda env vars)
HISTORY_TABLE=TibetCompassHistory
LOGS_TABLE=TibetCompassLogs

# API Gateway URL (filled in by deploy.sh)
API_GATEWAY_URL=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/prod/ask

# Amplify App URL (filled in by deploy.sh)
AMPLIFY_URL=https://main.YOUR_APP_ID.amplifyapp.com

# Model ID
MODEL_ID=amazon.nova-lite-v1:0
